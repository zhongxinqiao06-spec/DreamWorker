{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dreamworker.dev/agent/v0.1/schema.json",
  "title": "AgentSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "role",
    "input_schema",
    "output_schema",
    "allowed_capabilities",
    "default_model_profile",
    "budget",
    "timeout",
    "approval_policy",
    "expected_artifacts",
    "prompt_ref"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "id": {
      "enum": [
        "orchestrator",
        "product_analyst",
        "competitor_analyst",
        "tech_architect",
        "growth_agent",
        "evaluator"
      ]
    },
    "role": { "type": "string", "minLength": 1 },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "allowed_capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^cap_[A-Za-z0-9_-]+$" }
    },
    "default_model_profile": { "type": "string", "minLength": 1 },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_tokens", "max_cost_usd"],
      "properties": {
        "max_tokens": { "type": "integer", "minimum": 1 },
        "max_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "timeout": { "type": "string", "pattern": "^[0-9]+(ms|s|m)$" },
    "approval_policy": { "enum": ["never", "on_risk", "always"] },
    "expected_artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "prompt_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_id", "prompt_version", "agent_id"],
      "properties": {
        "prompt_id": { "type": "string", "pattern": "^prm_[A-Za-z0-9_-]+$" },
        "prompt_version": { "type": "string", "pattern": "^v[0-9]+$" },
        "agent_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
