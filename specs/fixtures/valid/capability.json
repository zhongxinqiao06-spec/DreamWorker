{
  "apiVersion": "capability.dreamworker.dev/v1",
  "kind": "builtin",
  "metadata": {
    "id": "cap_artifact_write",
    "name": "Artifact Write",
    "version": "0.1.0",
    "provider": "dreamworker"
  },
  "protocol": {
    "type": "builtin"
  },
  "inputSchema": {
    "type": "object"
  },
  "outputSchema": {
    "type": "object"
  },
  "permissions": {
