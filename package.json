{
  "name": "dreamworker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DreamWorker open AI project incubator operating system",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace @dreamworker/desktop run dev",
    "lint": "eslint \"apps/desktop/**/*.{ts,vue}\" \"scripts/**/*.mjs\" \"eslint.config.js\"",
    "format:check": "node scripts/format-check.mjs",
    "specs:validate": "node scripts/validate-specs.mjs",
    "specs:generate": "node scripts/generate-contracts.mjs",
    "specs:check": "node scripts/generate-contracts.mjs --check && npm run specs:validate",
    "typecheck": "npm --workspace @dreamworker/desktop run typecheck",
    "test": "npm --workspace @dreamworker/desktop run test",
    "runtime:check": "node scripts/check-desktop-runtime.mjs",
    "package:win": "npm run build && npm run runtime:check && npm --workspace @dreamworker/desktop run package:win",
    "security:smoke": "node scripts/security-smoke.mjs",
    "llm:smoke": "node scripts/deepseek-smoke.mjs",
    "llm:long-task": "node scripts/deepseek-smoke.mjs --long-task",
    "build": "npm run typecheck && npm --workspace @dreamworker/desktop run build",
    "ci": "npm run lint && npm run format:check && npm run specs:check && npm run typecheck && npm test && npm run runtime:check && npm run security:smoke"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.9.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.1"
  }
}
