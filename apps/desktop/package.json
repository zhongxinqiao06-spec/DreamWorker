{
  "name": "@dreamworker/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "description": "DreamWorker desktop workspace shell",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:win": "electron-builder --win nsis",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.5",
    "@anthropic-ai/claude-agent-sdk": "0.3.201",
    "@electron-toolkit/utils": "^4.0.0",
    "@openai/codex-sdk": "0.142.5",
    "@opencode-ai/cli": "1.17.13",
    "@opencode-ai/sdk": "1.17.13",
    "echarts": "^6.1.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "build": {
    "appId": "dev.dreamworker.desktop",
    "productName": "DreamWorker",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "out/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../.agent",
        "to": ".agent"
      }
    ],
    "asarUnpack": [
      "node_modules/@opencode-ai/**",
      "node_modules/@anthropic-ai/**",
      "node_modules/@openai/**",
      "node_modules/@ai-sdk/**"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "shortcutName": "DreamWorker",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "electron": "38.8.6",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.0.0"
  }
}
